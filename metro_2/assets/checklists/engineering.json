{
  "work_type": "engineering",
  "title": "Замер инженерных систем",
  "fields": [
    {
      "id": "system_type",
      "type": "select",
      "label": "Тип системы",
      "required": true,
      "options": ["Котельная", "Отопление", "Водоснабжение", "Канализация", "Вентиляция"]
    },
    {
      "id": "room_area",
      "type": "number",
      "label": "Площадь помещения (м²)",
      "hint": "м²"
    },
    {
      "id": "ceiling_height",
      "type": "number",
      "label": "Высота потолка (мм)",
      "hint": "мм"
    },
    {
      "id": "boiler_type",
      "type": "select",
      "label": "Тип котла",
      "options": ["Газовый", "Электрический", "Твёрдотопливный", "Жидкотопливный"],
      "condition": {
        "field": "system_type",
        "operator": "equals",
        "value": "Котельная"
      }
    },
    {
      "id": "boiler_power",
      "type": "number",
      "label": "Мощность котла (кВт)",
