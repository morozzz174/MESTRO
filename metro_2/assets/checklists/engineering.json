        "field": "system_type",
        "operator": "equals",
        "value": "Котельная"
      }
    },
    {
      "id": "chimney_diameter",
      "type": "number",
      "label": "Диаметр дымохода (мм)",
      "hint": "мм",
      "condition": {
        "field": "system_type",
        "operator": "equals",
        "value": "Котельная"
      }
    },
    {
      "id": "chimney_height",
      "type": "number",
      "label": "Высота дымохода (м)",
