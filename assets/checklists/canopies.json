{
  "work_type": "canopies",
  "title": "Замер навесов и беседок",
  "fields": [
    {
      "id": "structure_type",
      "type": "select",
      "label": "Тип конструкции",
      "required": true,
      "options": ["навес", "беседка", "терраса", "пергола", "веранда"]
    },
    {
      "id": "length",
      "type": "number",
      "label": "Длина (м)",
      "required": true,
      "hint": "м"
    },
    {
      "id": "width",
      "type": "number",
      "label": "Ширина (м)",
      "required": true,
      "hint": "м"
    },
    {
      "id": "height",
      "type": "number",
      "label": "Высота (м)",
      "required": true,
      "hint": "м"
    },
    {
      "id": "area",
      "type": "number",
      "label": "Площадь (м²)",
      "hint": "м²"
    },
    {
      "id": "roof_type",
      "type": "select",
      "label": "Тип кровли",
      "options": ["односкатная", "двускатная", "четырёхскатная", "полувальмовая", "плоская", "купольная"]
    },
    {
      "id": "roof_material",
      "type": "select",
      "label": "Материал кровли",
      "options": ["металлочерепица", "профнастил", "мягкая черепица", "поликарбонат", "ондулин", "тент", "черепица"]
    },
    {
      "id": "frame_material",
      "type": "select",
      "label": "Материал каркаса",
      "options": ["металл", "дерево", "кирпич", "бетон", "комбинированный"]
    },
    {
      "id": "post_count",
      "type": "number",
      "label": "Количество столбов",
      "hint": "шт"
    },
    {
      "id": "post_material",
      "type": "select",
      "label": "Материал столбов",
      "options": ["металлические", "деревянные", "кирпичные", "бетонные"]
    },
    {
      "id": "post_size",
      "type": "text",
      "label": "Размер сечения столбов",
      "hint": "например: 100х100 мм"
    },
    {
      "id": "has_foundation",
      "type": "boolean",
      "label": "Нужен фундамент"
    },
    {
      "id": "foundation_type",
      "type": "select",
      "label": "Тип фундамента",
      "options": ["ленточный", "столбчатый", "плита", "винтовые сваи"],
      "condition": {
        "field": "has_foundation",
        "operator": "equals",
        "value": true
      }
    },
    {
      "id": "has_walls",
      "type": "boolean",
      "label": "Наличие стен (полное или частичное)"
    },
    {
      "id": "wall_material",
      "type": "select",
      "label": "Материал стен",
      "options": ["деревянный брус", "блоки", "кирпич", "металл", "поликарбонат"],
      "condition": {
        "field": "has_walls",
        "operator": "equals",
        "value": true
      }
    },
    {
      "id": "has_floor",
      "type": "boolean",
      "label": "Настил пола"
    },
    {
      "id": "floor_material",
      "type": "select",
      "label": "Материал пола",
      "options": ["деревянная доска", "террасная доска", "плитка", "бетон", "щебень"],
      "condition": {
        "field": "has_floor",
        "operator": "equals",
        "value": true
      }
    },
    {
      "id": "has_lighting",
      "type": "boolean",
      "label": "Освещение"
    },
    {
      "id": "has_electrical",
      "type": "boolean",
      "label": "Электричество"
    },
    {
      "id": "has_grill",
      "type": "boolean",
      "label": "Мангал/барбекю"
    },
    {
      "id": "placement",
      "type": "select",
      "label": "Расположение",
      "options": ["отдельностоящая", "пристройка к дому", "навес у бани"]
    },
    {
      "id": "ground_type",
      "type": "select",
      "label": "Тип грунта",
      "options": ["ровный", "уклон", "неровный"]
    },
    {
      "id": "access_type",
      "type": "select",
      "label": "Подъезд",
      "options": ["легковой", "грузовой", "нет подъезда"]
    },
    {
      "id": "notes",
      "type": "text",
      "label": "Примечания",
      "hint": "Дополнительная информация"
    }
  ]
}