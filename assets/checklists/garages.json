      "type": "select",
      "label": "Утеплитель",
      "options": ["минеральная вата", "пенопласт", "пенополиуретан"],
      "condition": {
        "field": "has_insulation",
        "operator": "equals",
        "value": true
      }
    },
    {
      "id": "roof_type",
