      "label": "Тип гаража",
      "required": true,
      "options": ["отдельностоящий", "пристройка", "встроенный", "металлический", "капитальный"]
    },
    {
      "id": "length",
      "type": "number",
      "label": "Длина (м)",
      "required": true,
      "hint": "м"
    },
    {
      "id": "width",
      "type": "number",
      "label": "Ширина (м)",
      "required": true,
      "hint": "м"
    },
    {
      "id": "height",
      "type": "number",
      "label": "Высота (м)",
      "required": true,
      "hint": "м"
