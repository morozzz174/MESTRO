# uCaller API credentials
# Получите в личном кабинете: https://ucaller.ru/cabinet/
# 1. Зарегистрируйтесь на ucaller.ru
# 2. Перейдите в Кабинет → Интеграция → API
# 3. Скопируйте Service ID и Secret Key
UCALLER_SERVICE_ID=your_service_id_here
UCALLER_SECRET_KEY=your_secret_key_here

# YooKassa (ЮKassa) API credentials
# Получите в личном кабинете: https://yookassa.ru/my/merchant/integration
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here
